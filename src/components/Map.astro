---
const territories = [
  { name: 'Vaughan', meta: 'GTA · HQ Territory', status: 'Hiring · Multiple roles', warm: false },
  { name: 'Hamilton', meta: 'Golden Horseshoe', status: 'Hiring · Leadership + Rep', warm: false },
  { name: 'London', meta: 'Southwestern ON', status: 'Waitlist', warm: true },
  { name: 'Barrie', meta: 'Simcoe County', status: 'Hiring · Reps', warm: false },
  { name: 'Oshawa', meta: 'Durham Region', status: 'Hiring · Reps', warm: false },
  { name: 'Markham', meta: 'York Region', status: 'Limited Seats', warm: true },
];
---

<section class="territories" id="territories">
  <div class="container">
    <div class="section-label" style="color: var(--blue);">04 / The Map</div>
    <h2 class="section-headline" style="color: var(--white);">Where we're<br /><span class="blue">building right now.</span></h2>
    <p class="section-intro" style="color: rgba(255,255,255,0.65); max-width: 640px;">Six live territories across Ontario. Each runs its own crew, its own trainer, its own promotion pipeline. Tap a region to see what's open.</p>

    <div class="territory-grid">
      {territories.map((t) => (
        <div class="territory">
          <div class="territory-name">{t.name}</div>
          <div class="territory-meta">{t.meta}</div>
          <span class={`territory-status ${t.warm ? 'warm' : ''}`}>
            <span class="pulse" style={t.warm ? 'background: var(--accent-orange);' : ''}></span>
            {t.status}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .territories {
    background: var(--ink); color: var(--white);
    position: relative; overflow: hidden;
  }
  .territories::before {
    content: ""; position: absolute; top: -100px; right: -100px;
    width: 400px; height: 400px; border-radius: 50%;
    background: var(--blue);
    opacity: 0.15;
    filter: blur(80px);
  }
  .territory-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px;
    background: rgba(255,255,255,0.1);
    margin-top: 40px;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .territory {
    background: var(--ink);
    padding: 36px 32px;
    transition: all 0.3s ease;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }
  .territory::before {
    content: ""; position: absolute; left: 0; top: 0; bottom: 0;
    width: 4px; background: var(--blue);
    transform: scaleY(0); transform-origin: bottom;
    transition: transform 0.3s ease;
  }
  .territory:hover { background: #1A1D24; }
  .territory:hover::before { transform: scaleY(1); }
  .territory-name {
    font-family: 'Archivo Black', sans-serif;
    font-size: 30px; text-transform: uppercase;
    margin-bottom: 10px;
    line-height: 1;
  }
  .territory-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: rgba(255,255,255,0.5);
    text-transform: uppercase; letter-spacing: 0.15em;
    margin-bottom: 18px;
  }
  .territory-status {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 12px; font-weight: 600;
    padding: 6px 12px;
    background: rgba(198,255,61,0.15);
    color: var(--accent-lime);
    border-radius: 4px;
  }
  .territory-status.warm { background: rgba(255,90,31,0.15); color: var(--accent-orange); }

  @media (max-width: 1024px) {
    .territory-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .territory-grid { grid-template-columns: 1fr; }
  }
</style>
