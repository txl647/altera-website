---
const rungs = [
  { num: '01', meta: 'Month 1–3', title: 'Field Rep', desc: "Learn the product, own the script, hit your first clean week. You're in the field with a trainer every day.", earn: 'Commission + weekly bonuses' },
  { num: '02', meta: 'Month 3–6', title: 'Senior Rep', desc: 'Consistent production, objection-proof, mentoring new hires on ride-alongs. Your pipeline is your own.', earn: 'Raised commission tier' },
  { num: '03', meta: 'Month 6–12', title: 'Field Lead', desc: 'Running your own micro-crew, owning a sub-territory, responsible for onboarding the next wave of reps.', earn: 'Override + leadership bonus' },
  { num: '04', meta: 'Year 1+', title: 'Territory Owner', desc: 'Operator-level scope. P&L responsibility for your region. Equity conversations happen at this gate.', earn: 'Override + vested equity path' },
];
---

<section class="path" id="path">
  <div class="container">
    <div class="section-label">03 / The Path</div>
    <h2 class="section-headline">Four rungs.<br />No fake titles.</h2>
    <p class="section-intro">Every stage at Altera has a defined scope, a defined payout model, and a defined promotion gate. If you're doing the work, the next rung is already built for you.</p>

    <div class="ladder">
      {rungs.map((rung) => (
        <div class="ladder-step">
          <div class="ladder-num">{rung.num}</div>
          <div class="ladder-meta">{rung.meta}</div>
          <h4>{rung.title}</h4>
          <p>{rung.desc}</p>
          <div class="ladder-earn">{rung.earn}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .path { background: var(--white); }
  .ladder {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 3px solid var(--ink);
    overflow: hidden;
    margin-top: 48px;
  }
  .ladder-step {
    padding: 40px 32px;
    position: relative;
    background: var(--white);
    border-right: 3px solid var(--ink);
    min-height: 340px;
    display: flex; flex-direction: column;
  }
  .ladder-step:last-child { border-right: none; }
  .ladder-step:nth-child(1) { background: var(--gray-100); }
  .ladder-step:nth-child(2) { background: var(--blue-tint); }
  .ladder-step:nth-child(3) { background: var(--blue); color: var(--ink); }
  .ladder-step:nth-child(4) { background: var(--ink); color: var(--white); }
  .ladder-num {
    font-family: 'Archivo Black', sans-serif;
    font-size: 88px; line-height: 0.85;
    letter-spacing: -0.04em;
    color: rgba(0,0,0,0.1);
    position: absolute;
    top: 18px; right: 22px;
  }
  .ladder-step:nth-child(4) .ladder-num { color: rgba(255,255,255,0.08); }
  .ladder-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.15em;
    margin-bottom: 12px;
    opacity: 0.7;
  }
  .ladder-step h4 {
    font-family: 'Archivo Black', sans-serif;
    font-size: 26px; line-height: 0.95;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .ladder-step p { font-size: 14px; line-height: 1.55; margin-bottom: auto; opacity: 0.85; }
  .ladder-earn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px; font-weight: 700;
    padding-top: 18px;
    border-top: 1.5px solid currentColor;
    margin-top: 22px;
    opacity: 0.9;
  }

  @media (max-width: 1024px) {
    .ladder { grid-template-columns: 1fr 1fr; }
    .ladder-step:nth-child(2) { border-right: none; }
    .ladder-step:nth-child(1), .ladder-step:nth-child(2) { border-bottom: 3px solid var(--ink); }
  }
  @media (max-width: 640px) {
    .ladder { grid-template-columns: 1fr; }
    .ladder-step { border-right: none; border-bottom: 3px solid var(--ink); }
    .ladder-step:last-child { border-bottom: none; }
  }
</style>
