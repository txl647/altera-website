---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Altera — Where Operators Are Built.",
  description = "Altera is Ontario's operator-first field sales organization. We don't hire reps. We build operators. Heat pumps, home energy upgrades, uncapped earning, structured growth.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Bebas+Neue&family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@500;700&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <slot />
</body>
</html>

<script>
  const nav = document.getElementById('nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 30);
    });
  }
</script>
